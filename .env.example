# Copy this file to .env and fill in your values.
# `.env` is git-ignored; `.env.example` is committed as a template.
# FlowDoc does not auto-load .env — set the var in your shell
# (per-session `export`, your shell rc file, or `source` a file
# you wrote with `export` prefixes locally).

# Required for `flowdoc miro`.
# Generate at: https://miro.com/app/settings/user-profile/apps
# (Create new app → Install on this team → copy access token)
MIRO_ACCESS_TOKEN=
